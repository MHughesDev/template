# .envrc
# BLUEPRINT: Composer 2 implements from this structure
# PURPOSE: direnv configuration. Automatically loads .env and activates .venv when
#          entering this directory. Optional per spec §26.12 item 393.
#          Requires `direnv` installed and `direnv allow` run once in this directory.
# SECTIONS:
#   - Load .env if it exists (source_env or dotenv)
#   - Activate .venv if it exists (layout python or PATH_add)
#   - Print helpful message if .env is missing
# DESIGN DECISIONS:
#   - Uses direnv stdlib functions (dotenv, layout) for safety
#   - Falls back gracefully if .env or .venv doesn't exist
#   - Does NOT create .env — use scripts/generate-env.sh for that
#   - Add `.envrc` to .gitignore if you want per-machine customizations

# Load .env file if it exists
if [ -f .env ]; then
  dotenv .env
else
  echo "⚠ No .env file found. Run: cp .env.example .env && edit .env"
  echo "  Or run: make env:generate"
fi

# Activate Python virtual environment if it exists
if [ -d .venv ]; then
  layout python .venv/bin/python
else
  echo "⚠ No .venv found. Run: python -m venv .venv && pip install -e '.[dev]'"
  echo "  Or run: ./setup.sh"
fi
