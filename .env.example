# .env.example
# Copy to `.env` for local development. Never commit real secrets.

# =============================================================================
# DATABASE
# =============================================================================

# Primary database URL. SQLite for development; PostgreSQL for production.
# SQLite: sqlite+aiosqlite:///./dev.db
# PostgreSQL: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# Database pool settings (PostgreSQL only; ignored for SQLite)
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20
# DATABASE_POOL_TIMEOUT=30

# =============================================================================
# AUTH / JWT
# =============================================================================

# JWT signing secret. MUST be changed in production. Generate: openssl rand -hex 32
JWT_SECRET_KEY=CHANGEME-generate-with-openssl-rand-hex-32

# JWT algorithm (HS256 recommended for simple deployments; RS256 for public key auth)
JWT_ALGORITHM=HS256

# Access token expiry in minutes (short-lived for security)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiry in days
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# =============================================================================
# API
# =============================================================================

# Server host and port
API_HOST=0.0.0.0
API_PORT=8000

# Debug mode — NOT FOR PRODUCTION (enables auto-reload, verbose errors)
API_DEBUG=true

# CORS allowed origins (comma-separated). Use * only for dev.
# Production: set to your actual frontend origin(s)
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# API prefix for all routes (versioning)
API_PREFIX=/api/v1

# Allowed hosts (comma-separated). Used by TrustedHostMiddleware.
# Production: set to your actual domain(s)
API_ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# OPTIONAL: AI / RAG (ChromaDB profile)
# =============================================================================

# Enable AI/RAG features. Set to false to disable (kill switch)
# AI_ENABLED=false

# ChromaDB host and port (when ai profile is active)
# CHROMA_HOST=chroma
# CHROMA_PORT=8001

# ChromaDB collection name
# CHROMA_COLLECTION=default

# Embedding model provider (openai, local)
# EMBEDDING_PROVIDER=openai

# OpenAI API key (if using OpenAI embeddings)
# OPENAI_API_KEY=sk-CHANGEME

# =============================================================================
# OPTIONAL: WORKERS / BACKGROUND TASKS (worker profile)
# =============================================================================

# Worker broker URL (Redis or RabbitMQ)
# BROKER_URL=redis://redis:6379/0

# Result backend URL
# RESULT_BACKEND_URL=redis://redis:6379/1

# =============================================================================
# OBSERVABILITY
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log format: json (production) or text (development)
LOG_FORMAT=text

# OpenTelemetry collector endpoint (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Service name for distributed tracing
# OTEL_SERVICE_NAME=api

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable multi-tenancy enforcement (set to false to disable tenant middleware in single-tenant mode)
MULTI_TENANCY_ENABLED=false

# Enable rate limiting
RATE_LIMITING_ENABLED=false

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Seed admin user for development (created by make db:seed)
# DEV_ADMIN_EMAIL=admin@example.com
# DEV_ADMIN_PASSWORD=CHANGEME
