# .env.example
# Copy to .env for local development. Never commit real secrets.

# DATABASE
# SQLite (dev): sqlite+aiosqlite:///./dev.db
# Postgres: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# AUTH / JWT
JWT_SECRET_KEY=CHANGEME-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
API_PREFIX=/api/v1
API_ALLOWED_HOSTS=localhost,127.0.0.1

# OPTIONAL: AI / RAG (enable ai optional deps)
# AI_ENABLED=false
# CHROMA_HOST=localhost
# CHROMA_PORT=8000

# OBSERVABILITY
LOG_LEVEL=INFO
LOG_FORMAT=text

# FEATURE FLAGS
MULTI_TENANCY_ENABLED=false
RATE_LIMITING_ENABLED=false
